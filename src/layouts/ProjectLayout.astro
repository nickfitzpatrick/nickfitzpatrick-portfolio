---
import Base from './Base.astro';

interface Props {
  title: string;
  summary: string;
  tags: string[];
  status?: string;
  date?: string;
  github?: string;
  demo?: string;
}

const { title, summary, tags, status, date, github, demo } = Astro.props;
---
<Base title={title} description={summary}>
  <a href="/projects" class="muted" style="font-size:0.875rem;">← Projects</a>

  <div style="margin-top:1.5rem; margin-bottom:0.5rem;">
    {date && <span class="muted" style="font-size:0.8rem; font-family:var(--font-mono);">{date}</span>}
  </div>

  <h1 style="margin-bottom:0.75rem;">{title}</h1>
  <p style="font-size:1.05rem; color:var(--muted); margin-bottom:1.25rem; max-width:580px; line-height:1.7;">{summary}</p>

  <div class="tag-row" style="margin-bottom:1.75rem;">
    {tags.map(t => <span class="tag">{t}</span>)}
    {status && <span class={`tag ${status === 'In Progress' ? 'accent' : ''}`}>{status}</span>}
  </div>

  {(github || demo) && (
    <div style="display:flex; gap:0.75rem; margin-bottom:2.5rem; flex-wrap:wrap;">
      {github && <a href={github} target="_blank" class="btn-secondary">GitHub →</a>}
      {demo && <a href={demo} target="_blank" class="btn-primary">Live Demo →</a>}
    </div>
  )}

  <hr style="border:none; border-top:1px solid var(--border); margin-bottom:2.5rem;" />

  <div class="prose">
    <slot />
  </div>
</Base>
