---
// Design preview page -- not linked from nav, just for evaluation
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Design Preview</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #080808;
      font-family: 'Inter', system-ui, sans-serif;
      color: #e8e8e8;
      padding: 2rem;
    }

    .switcher {
      display: flex;
      gap: 1rem;
      margin-bottom: 2.5rem;
      align-items: center;
    }
    .switcher span { color: #666; font-size: 0.85rem; }
    .btn {
      padding: 0.5rem 1.25rem;
      border-radius: 6px;
      border: 1px solid #333;
      background: transparent;
      color: #e8e8e8;
      cursor: pointer;
      font-size: 0.875rem;
      transition: all 0.2s;
    }
    .btn.active { border-color: var(--accent); color: var(--accent); }

    /* ── Cyan theme ── */
    .theme-cyan { --accent: #38BDF8; --accent-dim: rgba(56,189,248,0.12); --accent-glow: rgba(56,189,248,0.25); }
    /* ── Slate theme ── */
    .theme-slate { --accent: #7B8CDE; --accent-dim: rgba(123,140,222,0.12); --accent-glow: rgba(123,140,222,0.25); }

    /* ── Shared tokens ── */
    .preview {
      --bg: #0c0c0c;
      --surface: #161616;
      --border: #242424;
      --text: #efefef;
      --muted: #777;
      --max-w: 1200px;
      background: var(--bg);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #1e1e1e;
      display: none;
    }
    .preview.active { display: block; }

    /* ── Nav ── */
    .p-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 3rem;
      border-bottom: 1px solid var(--border);
    }
    .p-nav-logo { font-weight: 700; font-size: 1rem; letter-spacing: -0.02em; color: var(--text); }
    .p-nav ul { list-style: none; display: flex; gap: 2.5rem; }
    .p-nav ul a { color: var(--muted); font-size: 0.875rem; text-decoration: none; transition: color 0.2s; }
    .p-nav ul a:hover { color: var(--text); }

    /* ── Hero ── */
    .p-hero {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 4rem;
      padding: 5rem 3rem 4rem;
      max-width: var(--max-w);
      margin: 0 auto;
      align-items: center;
    }
    .p-hero-text { animation: fadeUp 0.6s ease both; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .p-eyebrow { font-size: 0.8rem; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.75rem; font-weight: 500; }
    .p-h1 { font-size: 3.25rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.05; margin-bottom: 1.25rem; color: var(--text); }
    .p-tagline { font-size: 1.1rem; color: var(--muted); line-height: 1.7; max-width: 480px; margin-bottom: 2rem; }
    .p-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .p-btn-primary {
      background: var(--accent);
      color: #080808;
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.875rem;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .p-btn-primary:hover { opacity: 0.85; }
    .p-btn-secondary {
      border: 1px solid var(--border);
      color: var(--text);
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      font-size: 0.875rem;
      text-decoration: none;
      transition: border-color 0.2s;
    }
    .p-btn-secondary:hover { border-color: var(--accent); }

    /* ── Photo placeholder ── */
    .p-photo {
      width: 100%;
      aspect-ratio: 4/5;
      border-radius: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 0.8rem;
      gap: 0.5rem;
      animation: fadeUp 0.6s 0.15s ease both;
      position: relative;
      overflow: hidden;
    }
    .p-photo::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 60% 30%, var(--accent-glow), transparent 70%);
      pointer-events: none;
    }
    .p-photo svg { opacity: 0.3; }

    /* ── Currently strip ── */
    .p-currently {
      border-top: 1px solid var(--border);
      padding: 2.5rem 3rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .p-currently h2 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 1.25rem; }
    .p-currently ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    .p-currently li { display: flex; align-items: baseline; gap: 0.75rem; font-size: 0.95rem; color: var(--muted); }
    .p-currently li span.dot { width: 5px; height: 5px; background: var(--accent); border-radius: 50%; flex-shrink: 0; margin-top: 0.45rem; }
    .p-currently li strong { color: var(--text); }

    /* ── Projects section ── */
    .p-projects {
      padding: 3rem 3rem 4rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .p-section-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 1.75rem;
    }
    .p-section-header h2 { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; }
    .p-section-header a { font-size: 0.8rem; color: var(--accent); text-decoration: none; }
    .p-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .p-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: border-color 0.2s, transform 0.2s;
      cursor: pointer;
      animation: fadeUp 0.5s ease both;
    }
    .p-card:nth-child(2) { animation-delay: 0.08s; }
    .p-card:nth-child(3) { animation-delay: 0.16s; }
    .p-card:hover { border-color: var(--accent); transform: translateY(-3px); }
    .p-card-img {
      width: 100%;
      aspect-ratio: 16/9;
      background: #111;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 0.75rem;
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }
    .p-card-img::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--accent-dim), transparent);
    }
    .p-card-body { padding: 1.25rem; }
    .p-card-body h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text); }
    .p-card-body p { font-size: 0.825rem; color: var(--muted); line-height: 1.55; margin-bottom: 0.75rem; }
    .p-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .p-tag {
      font-size: 0.7rem;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      border: 1px solid var(--border);
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
    }
    .p-tag.accent { border-color: var(--accent); color: var(--accent); }

    /* ── Footer ── */
    .p-footer {
      border-top: 1px solid var(--border);
      padding: 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--muted);
      font-size: 0.8rem;
    }
    .p-footer a { color: var(--muted); text-decoration: none; }
    .p-footer a:hover { color: var(--accent); }
    .p-footer-links { display: flex; gap: 1.5rem; }

    /* ── Mobile note ── */
    .note { color: #555; font-size: 0.8rem; margin-top: 1.5rem; }
  </style>
</head>
<body>

<div class="switcher">
  <span>Accent color:</span>
  <button class="btn active" onclick="setTheme('cyan', this)">Cyan #38BDF8</button>
  <button class="btn" onclick="setTheme('slate', this)">Slate #7B8CDE</button>
</div>

<!-- ══ PREVIEW WRAPPER ══ -->
<div id="preview" class="preview theme-cyan active">

  <!-- Nav -->
  <nav class="p-nav">
    <span class="p-nav-logo">Nick Fitzpatrick</span>
    <ul>
      <li><a href="#">Projects</a></li>
      <li><a href="#">Resume</a></li>
      <li><a href="#">About</a></li>
    </ul>
  </nav>

  <!-- Hero -->
  <section class="p-hero">
    <div class="p-hero-text">
      <p class="p-eyebrow">AI Product &amp; Operations</p>
      <h1 class="p-h1">Nick<br/>Fitzpatrick</h1>
      <p class="p-tagline">
        I build systems that connect machine learning to real decisions —
        from last-mile logistics to generative design for architecture.
      </p>
      <div class="p-cta">
        <a href="#" class="p-btn-primary">View Projects</a>
        <a href="#" class="p-btn-secondary">Resume</a>
      </div>
    </div>
    <div class="p-photo">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      <span>Your photo here</span>
    </div>
  </section>

  <!-- Currently -->
  <div class="p-currently">
    <h2>Currently</h2>
    <ul>
      <li><span class="dot"></span><span>Product &amp; data engineering intern at <strong>Geopogo</strong> — AI visualization for architecture</span></li>
      <li><span class="dot"></span><span>Building <strong>RouteMorph</strong> — explainable AI for last-mile delivery optimization</span></li>
      <li><span class="dot"></span><span>Contract AI/RLHF data work</span></li>
    </ul>
  </div>

  <!-- Projects -->
  <section class="p-projects">
    <div class="p-section-header">
      <h2>Selected Projects</h2>
      <a href="#">View all →</a>
    </div>
    <div class="p-grid">
      <div class="p-card">
        <div class="p-card-img">
          <span>Project image</span>
        </div>
        <div class="p-card-body">
          <h3>RouteMorph</h3>
          <p>Explainable AI for last-mile delivery route optimization with a conversational interface.</p>
          <div class="p-tags">
            <span class="p-tag">Python</span>
            <span class="p-tag">OR-Tools</span>
            <span class="p-tag">ML</span>
            <span class="p-tag accent">In Progress</span>
          </div>
        </div>
      </div>
      <div class="p-card">
        <div class="p-card-img"><span>Project image</span></div>
        <div class="p-card-body">
          <h3>Geopogo ADA Tool</h3>
          <p>AI-powered ADA compliance checker for architectural drawings using computer vision.</p>
          <div class="p-tags">
            <span class="p-tag">Python</span>
            <span class="p-tag">CV</span>
            <span class="p-tag">Streamlit</span>
          </div>
        </div>
      </div>
      <div class="p-card">
        <div class="p-card-img"><span>Project image</span></div>
        <div class="p-card-body">
          <h3>Weekend Project</h3>
          <p>Placeholder for gap-filling project TBD based on resume analysis.</p>
          <div class="p-tags">
            <span class="p-tag">TBD</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="p-footer">
    <span>nickfitzpatrick.dev</span>
    <div class="p-footer-links">
      <a href="#">GitHub</a>
      <a href="#">LinkedIn</a>
      <a href="#">Email</a>
    </div>
  </footer>

</div>

<p class="note">This is a design preview only — not linked from the main site. Visit <code>/dev/preview</code> to evaluate.</p>

<script>
  function setTheme(theme, btn) {
    const preview = document.getElementById('preview');
    preview.className = `preview theme-${theme} active`;
    document.querySelectorAll('.btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }
</script>
</body>
</html>
